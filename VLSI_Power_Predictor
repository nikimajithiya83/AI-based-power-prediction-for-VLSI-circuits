def get_float(prompt, min_val, max_val, unit='', example=''):
    while True:
        print(f"\n  Range   : {min_val} to {max_val} {unit}")
        if example:
            print(f"  Example : {example}")
        try:
            val = float(input(f"  {prompt}: ").strip())
            if min_val <= val <= max_val:
                return val
            print(f"  Must be between {min_val} and {max_val} {unit}")
        except (ValueError, EOFError):
            print("  Invalid. Enter a number.")


def get_int(prompt, min_val, max_val, unit='', example=''):
    while True:
        print(f"\n  Range   : {min_val} to {max_val} {unit}")
        if example:
            print(f"  Example : {example}")
        try:
            val = int(input(f"  {prompt}: ").strip())
            if min_val <= val <= max_val:
                return val
            print(f"  Must be between {min_val} and {max_val}")
        except (ValueError, EOFError):
            print("  Invalid. Enter a whole number.")


def get_choice(prompt, options, example=''):
    while True:
        print(f"\n  Options : {' | '.join(options)}")
        if example:
            print(f"  Example : {example}")
        val = input(f"  {prompt}: ").strip().lower()
        if val in options:
            return val
        print(f"  Must be one of: {options}")


