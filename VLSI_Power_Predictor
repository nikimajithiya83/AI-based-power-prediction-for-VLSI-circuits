# ============================================================
# HELPER: ROBUST FILENAME PARSER
# Handles RISCY, RISCY-FPU, zero-riscy naming patterns
# ============================================================

def parse_filename(filename):
    parts     = filename.replace('.npy', '').split('-')
    clock_idx = None
    for i, p in enumerate(parts):
        if p.startswith('c') and p[1:].isdigit():
            clock_idx = i
            break
    if clock_idx is None:
        raise ValueError(f"Could not parse filename: {filename}")

    return {
        'design_id':   parts[0],
        'design_name': '-'.join(parts[1:clock_idx - 1]),
        'variant':     parts[clock_idx - 1],
        'clock_ns':    int(parts[clock_idx].replace('c', '')),
        'utilization': float(parts[clock_idx + 1].replace('u', '')),
        'macro_place': int(parts[clock_idx + 2].replace('m', '')),
        'power_mesh':  int(parts[clock_idx + 3].replace('p', '')),
        'filler':      int(parts[clock_idx + 4].replace('f', '')),
    }


# ============================================================
# HELPER: EXTRACT NAMED MODULE POWER FROM IR DROP MAP
# ============================================================

def extract_module_power(ir_map, design_name):
    rows, cols = ir_map.shape
    layout     = MODULE_LAYOUT.get(design_name, MODULE_LAYOUT['RISCY'])
    stats      = {}

    for m in layout:
        r0 = int(m['r0'] * rows);  r1 = int(m['r1'] * rows)
        c0 = int(m['c0'] * cols);  c1 = int(m['c1'] * cols)
        region = ir_map[r0:r1, c0:c1]
        stats[m['name']] = {
            'mean_ir':     float(region.mean()),
            'max_ir':      float(region.max()),
            'std_ir':      float(region.std()),
            'hotspot_pct': float((region > region.mean() + 2 * region.std()).mean()),
            'bounds':      (r0, r1, c0, c1)
        }

    return stats


# ============================================================
# HELPER: PARAMETER MAPPING
# Maps real engineering inputs to dataset feature space
# ============================================================

def map_params(clock_mhz, util_pct, num_macros, pdn_layers,
               gate_count, placement, filler_stage):
    clock_ns    = min([2, 5, 20], key=lambda x: abs(x - round(1000 / clock_mhz)))
    utilization = round(min([0.70, 0.75, 0.80, 0.85, 0.90],
                            key=lambda x: abs(x - util_pct / 100)), 2)
    macros      = min(3, max(1, round(num_macros / 5) + 1))
    power_mesh  = min(8, max(1, round(pdn_layers * 0.8)))
    variant     = 'a' if gate_count <= 100 else 'b'
    macro_place = {'edge': 1, 'center': 2, 'distributed': 3}.get(
                    str(placement).strip().lower(), 1)
    filler      = 1 if str(filler_stage).strip().lower() == 'routing' else 0

    return {
        'design_name': 'RISCY',
        'variant':      variant,
        'macros':       macros,
        'clock_ns':     clock_ns,
        'utilization':  utilization,
        'macro_place':  macro_place,
        'power_mesh':   power_mesh,
        'filler':       filler,
    }


# ============================================================
# HELPER: MODULE-LEVEL RECOMMENDATIONS
# ============================================================

def get_module_recommendations(module_name, mean_ir,
                                threshold_high, threshold_moderate):
    knowledge = MODULE_KNOWLEDGE.get(module_name, None)

    if mean_ir >= threshold_high:
        severity = 'HIGH'
        recs = (knowledge['recs']['high'] if knowledge
                else ["Apply clock gating on this module",
                      "Reduce switching activity — profile toggle rates"])
    elif mean_ir >= threshold_moderate:
        severity = 'MODERATE'
        recs = (knowledge['recs']['moderate'] if knowledge
                else ["Monitor this module — consider clock gating if power increases"])
    else:
        severity = 'LOW'
        recs = ["Module is operating within acceptable power range. No action needed."]

    source = knowledge['primary_power_source'] if knowledge else "switching activity"
    return severity, source, recs


# ============================================================
# HELPER: BUILD IR DROP MAP FOR VS CODE
# ============================================================

def build_ir_map(design_params, pred, ir_drop_path, df):
    MAP_SIZE = 128

    if os.path.exists(ir_drop_path):
        files = [f for f in os.listdir(ir_drop_path)
                 if f.endswith('.npy') or '.' not in f]

        if files:
            df['distance'] = (
                (df['clock_ns']    - design_params['clock_ns']).abs() * 10
                + (df['utilization'] - design_params['utilization']).abs() * 5
                + (df['power_mesh']  - design_params['power_mesh']).abs()
            )
            closest      = df.nsmallest(1, 'distance').iloc[0]
            sample_index = int(closest.name) % len(files)
            sample_file  = files[sample_index]
            raw          = np.load(os.path.join(ir_drop_path, sample_file))

            if raw.ndim == 2 and min(raw.shape) >= 32:
                print(f"  Using real IR drop map: {sample_file}  shape={raw.shape}")
                ir_map = raw.astype(float)
                r_min, r_max = ir_map.min(), ir_map.max()
                if r_max - r_min > 1e-9:
                    ir_map = (ir_map - r_min) / (r_max - r_min)
                return ir_map, sample_file

            flat = raw.flatten().astype(float)
            print(f"  Seeding heatmap from feature vector: {sample_file}")
        else:
            flat = np.random.rand(64)
            sample_file = "synthetic"
            print("  IR_drop/ folder is empty — using synthetic heatmap")
    else:
        flat = np.random.rand(64)
        sample_file = "synthetic"
        print("  IR_drop/ folder not found — using synthetic heatmap")

    np.random.seed(int(abs(flat.sum() * 1000)) % (2 ** 31))
    base      = np.random.rand(MAP_SIZE, MAP_SIZE)
    n_feat    = len(flat)
    norm_feat = (flat - flat.min()) / (flat.max() - flat.min() + 1e-9)

    for idx, val in enumerate(norm_feat):
        row = int((idx / n_feat) * MAP_SIZE)
        col = int(((idx * 7) % n_feat / n_feat) * MAP_SIZE)
        r0  = max(0, row - 8);  r1 = min(MAP_SIZE, row + 8)
        c0  = max(0, col - 8);  c1 = min(MAP_SIZE, col + 8)
        base[r0:r1, c0:c1] += val * 1.5

    base   = base * (0.5 + pred * 3.0)
    ir_map = gaussian_filter(base, sigma=6)
    d_min, d_max = ir_map.min(), ir_map.max()
    if d_max - d_min > 1e-9:
        ir_map = (ir_map - d_min) / (d_max - d_min)
    else:
        ir_map = np.zeros_like(ir_map)

    return ir_map, sample_file


# ============================================================
# HELPER: PLOT MODULE HEATMAP (named RTL modules)
# ============================================================

def plot_module_heatmap(ir_map, design_name, sample_name, save_path='module_heatmap.png'):
    layout       = MODULE_LAYOUT.get(design_name, MODULE_LAYOUT['RISCY'])
    rows, cols   = ir_map.shape
    module_stats = extract_module_power(ir_map, design_name)

    fig, axes = plt.subplots(1, 2, figsize=(16, 6))
    tab_colors = plt.cm.tab10.colors

    # ── Left: IR drop map with named module boundaries ───────────
    ax = axes[0]
    im = ax.imshow(ir_map, cmap='hot', interpolation='nearest', vmin=0, vmax=1)
    plt.colorbar(im, ax=ax, label='IR Drop (proxy for power)')

    for i, m in enumerate(layout):
        r0 = int(m['r0'] * rows);  r1 = int(m['r1'] * rows)
        c0 = int(m['c0'] * cols);  c1 = int(m['c1'] * cols)
        mean_val = module_stats[m['name']]['mean_ir']

        rect = mpatches.Rectangle(
            (c0, r0), c1 - c0, r1 - r0,
            linewidth=2, edgecolor=tab_colors[i % 10],
            facecolor='none', linestyle='--'
        )
        ax.add_patch(rect)
        ax.text(
            (c0 + c1) / 2, (r0 + r1) / 2,
            f"{m['name']}\n{mean_val:.3f}",
            ha='center', va='center', fontsize=7,
            color='white', fontweight='bold',
            bbox=dict(boxstyle='round,pad=0.2',
                      facecolor=tab_colors[i % 10], alpha=0.6)
        )

    ax.set_title(f'IR Drop Map with Module Boundaries\n{sample_name}', fontsize=10)
    ax.set_xlabel('Column tiles')
    ax.set_ylabel('Row tiles')

    # ── Right: Ranked bar chart ───────────────────────────────────
    ax2          = axes[1]
    sorted_mods  = sorted(module_stats.items(), key=lambda x: -x[1]['mean_ir'])
    mod_names    = [m[0] for m in sorted_mods]
    mod_vals     = [m[1]['mean_ir'] for m in sorted_mods]
    threshold    = np.percentile(mod_vals, 60)
    bar_colors   = ['#d62728' if v >= threshold else '#1f77b4' for v in mod_vals]

    bars = ax2.barh(mod_names[::-1], mod_vals[::-1], color=bar_colors[::-1])
    ax2.axvline(threshold, color='orange', linestyle='--',
                linewidth=1.5, label='Hotspot threshold')
    ax2.set_xlabel('Mean IR Drop (Power Proxy)')
    ax2.set_title('Module Power Ranking\n(Red = Power-Hungry)', fontsize=10)
    ax2.legend(fontsize=8)

    for bar, val in zip(bars, mod_vals[::-1]):
        ax2.text(bar.get_width() + 0.002,
                 bar.get_y() + bar.get_height() / 2,
                 f'{val:.4f}', va='center', fontsize=8)

    plt.suptitle(f'Module-Level Power Analysis — {design_name}',
                 fontsize=12, fontweight='bold')
    plt.tight_layout()
    plt.savefig(save_path, dpi=120)
    plt.show()
    print(f"  Saved: {save_path}")


# ============================================================
# HELPER: FULL MODULE REPORT (named RTL modules)
# ============================================================

def full_module_report(ir_map, design_name, design_params=None):
    module_stats = extract_module_power(ir_map, design_name)
    all_means    = [s['mean_ir'] for s in module_stats.values()]

    threshold_high     = np.percentile(all_means, 70)
    threshold_moderate = np.percentile(all_means, 40)

    sorted_modules = sorted(module_stats.items(), key=lambda x: -x[1]['mean_ir'])

    print('\n' + '=' * 65)
    print('       MODULE-LEVEL POWER DISSIPATION REPORT')
    print('=' * 65)
    if design_params:
        clock = design_params.get('clock_ns', 'N/A')
        util  = design_params.get('utilization', 0)
        print(f"  Design     : {design_name}")
        print(f"  Clock      : {clock} ns  ({1000 // clock} MHz)")
        print(f"  Utilization: {util * 100:.0f}%")
    print(f"  Modules analyzed  : {len(module_stats)}")
    print(f"  Hotspot threshold : mean_IR > {threshold_high:.4f}")
    print('=' * 65)

    for rank, (mod_name, stats) in enumerate(sorted_modules, 1):
        severity, source, recs = get_module_recommendations(
            mod_name, stats['mean_ir'], threshold_high, threshold_moderate
        )
        emoji = {'HIGH': '🔴', 'MODERATE': '🟡', 'LOW': '🟢'}.get(severity, '')
        print(f"\n  [{rank}] {mod_name}  {emoji} {severity}")
        print(f"       Mean IR Drop  : {stats['mean_ir']:.4f}")
        print(f"       Max IR Drop   : {stats['max_ir']:.4f}")
        print(f"       Hotspot tiles : {stats['hotspot_pct'] * 100:.1f}%")
        print(f"       Power source  : {source}")
        print(f"       Recommendations:")
        for i, r in enumerate(recs, 1):
            print(f"         {i}. {r}")

    high_mods = [m for m, s in sorted_modules
                 if s['mean_ir'] >= threshold_high]
    print('\n' + '=' * 65)
    print(f"  SUMMARY: {len(high_mods)} power-hungry module(s) identified:")
    for m in high_mods:
        print(f"    🔴 {m}")
    print('=' * 65)

    return module_stats


